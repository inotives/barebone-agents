# barebone-agent environment configuration
# Copy to .env and fill in your API keys

# LLM Provider Keys
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Platform Settings (all optional — defaults shown)
# SQLITE_DB_PATH=./data/barebone-agent.db
# LOG_LEVEL=info
# SESSION_TTL_MINUTES=30
# HISTORY_LIMIT=20
# MAX_TOOL_ITERATIONS=10
# TOOL_RESULT_MAX_CHARS=5000
# WORKSPACE_DIR=./workspace
# SESSION_FALLBACK_DIR=./data/sessions
# SUBAGENT_MAX_PARALLEL=3
# SUBAGENT_SLEEP_BETWEEN_SECS=5.0
# SKILLS_DIR=./skills
# SKILLS_TOKEN_BUDGET=4000
# SKILLS_MIN_MATCH_HITS=2
# HEARTBEAT_INTERVAL=60

# EP-00015 — local-first memory-aware workflow
# AKW_PUSH_INTERVAL=3600           # background pusher cycle interval, seconds (0 disables)
# PREFS_MIN_MATCH_HITS=2           # preference selector keyword overlap threshold
# PREFS_TOKEN_BUDGET=4000          # preference selector total token budget
# PRIOR_WORK_TOP_K=3               # prior-work search top hits per segment
# PRIOR_WORK_TOKEN_BUDGET=4000     # prior-work injection budget across hits
# REFLECTION_THRESHOLD=5           # counter threshold to fire reflection
# SESSION_DRAFT_INCLUDE_TURNS=true # include capped ## Turns appendix in session drafts
